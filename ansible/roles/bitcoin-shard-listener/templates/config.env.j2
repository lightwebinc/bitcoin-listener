# bitcoin-shard-listener environment configuration
# Managed by Ansible — do not edit manually

MULTICAST_IF={{ ingress_iface if ingress_iface is string else ingress_iface[0] }}
LISTEN_PORT={{ listen_port }}
SHARD_BITS={{ shard_bits }}
MC_SCOPE={{ mc_scope }}
MC_BASE_ADDR={{ mc_base_addr }}
SHARD_INCLUDE={{ shard_include }}
SUBTREE_INCLUDE={{ subtree_include }}
SUBTREE_EXCLUDE={{ subtree_exclude }}
EGRESS_ADDR={{ egress_addr }}
EGRESS_PROTO={{ egress_proto }}
STRIP_HEADER={{ 'true' if strip_header else 'false' }}
RETRY_ENDPOINTS={{ retry_endpoints }}
NACK_JITTER_MAX={{ nack_jitter_max }}
NACK_BACKOFF_MAX={{ nack_backoff_max }}
NACK_MAX_RETRIES={{ nack_max_retries }}
NACK_GAP_TTL={{ nack_gap_ttl }}
NUM_WORKERS={{ num_workers }}
METRICS_ADDR={{ metrics_addr }}
OTLP_ENDPOINT={{ otlp_endpoint }}
OTLP_INTERVAL={{ otlp_interval }}
DRAIN_TIMEOUT={{ drain_timeout }}
INSTANCE_ID={{ instance_id }}
DEBUG={{ 'true' if listener_debug else 'false' }}
